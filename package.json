{
  "name": "@ramselvan-m-20066/i18n-llm-translator",
  "type": "module",
  "description": "Smart i18n translation tool using LLM that only translates missing or invalid keys",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "i18n-translate": "./bin/i18n-translate"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\"",
    "prepublishOnly": "npm run build && npm test",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "llm",
    "openai",
    "gpt",
    "localization",
    "properties",
    "json",
    "cli"
  ],
  "author": "ramselvan-m-20066 <noreply@github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramselvan-m-20066/i18n-llm-translator.git"
  },
  "bugs": {
    "url": "https://github.com/ramselvan-m-20066/i18n-llm-translator/issues"
  },
  "homepage": "https://github.com/ramselvan-m-20066/i18n-llm-translator#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "glob": "^10.3.10",
    "jsonc-parser": "^3.2.0",
    "openai": "^4.20.0",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@types/node": "^20.0.0",
    "babel-jest": "^30.3.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-delete": "^2.0.0"
  }
}
